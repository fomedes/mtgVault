# ── MongoDB (Atlas M0 or local) ──────────────────────────────────────────
# SETUP.md §2 — the app always uses database name "mtg-vault"
MONGODB_URI=

# ── Firebase client SDK (public — safe to expose to the browser) ─────────
# SETUP.md §1 — Firebase console → Project settings → Your apps → Web app
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Firebase Admin SDK (SERVER ONLY — never expose, never commit) ────────
# SETUP.md §1 — service account JSON: project_id, client_email, private_key
# Keep the private key on one line with \n sequences, wrapped in quotes.
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=""

# ── Socket.io server ──────────────────────────────────────────────────────
# Keep SOCKET_PORT off 3000 (Next.js dev uses 3000).
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
SOCKET_PORT=4000
# Comma-separated allowlist of browser origins (e.g. your Vercel domain).
# localhost and private-LAN IPs (192.168.x / 10.x / 172.16–31.x) are ALWAYS
# allowed in code, so cross-device LAN testing works without listing each IP.
SOCKET_CORS_ORIGIN=http://localhost:3000,https://your-app.vercel.app
